{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slash",
  "version": "0.1.1-beta.18",
  "identifier": "new.slash",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Slash",
        "width": 1200,
        "height": 800,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' * ipc: http://ipc.localhost ipc://localhost data: blob: filesystem: about: ws: wss: asset: http://asset.localhost; media-src 'self' * data: blob: filesystem: asset: http://asset.localhost; img-src 'self' * data: blob: filesystem: asset: http://asset.localhost; connect-src 'self' * ipc: http://ipc.localhost ipc://localhost data: blob: filesystem: asset: http://asset.localhost;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "*/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "dmg"
    ],
    "resources": [
      "binaries/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Jasper Zhu (H83XQSDL83)",
      "entitlements": "entitlements.plist",
      "dmg": {
        "background": "icons/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://raw.githubusercontent.com/okzhu-al/slash-desktop/main/update.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEzREMyMEEyNTNCMkM5QTEKUldTaHliSlRvaURjbzUvQm4yQlFmOURJaVJXc0hmOVpYZXFoaHFRZnNMWnpYdjBMUE5HNndZL1MK"
    }
  }
}